# Simplex Web 版會把金鑰加密保存在設定頁，不需要修改本檔。
# 以下環境變數保留給舊有 MCP / Python 直調相容路徑。

# 原生 SearXNG（非 Docker 安裝預設由一鍵啟動器自動帶入）
SEARXNG_URL=http://127.0.0.1:8888

# 可選搜尋 API
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
SERPAPI_API_KEY=

# 舊有 MCP 完整 instant / fast / full 管線使用
OPENROUTER_API_KEY=

# 可選：保留給自訂 LLM transport
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# 可選：啟用詳細管線日誌
PRO_SEARCH_VERBOSE_LOGS=0
